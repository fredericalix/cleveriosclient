# Copy this file to fastlane/.env and fill in real OAuth tokens.
# fastlane/.env is git-ignored (covered by the global .env rule).
#
# How to obtain the tokens — see fastlane/README.md, "Step 1 — Obtain demo OAuth tokens".
# TL;DR: real OAuth login on the demo Clever Cloud account, then `po CCKeychainManager().loadCredentials()` in lldb.

UI_TEST_DEMO_MODE=1
UI_TEST_OAUTH_TOKEN=
UI_TEST_OAUTH_SECRET=
